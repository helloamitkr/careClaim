# CareBridge AI — LLM configuration.
# Copy this file to `.env` (repo root or backend/) and fill in your values.
# `.env` is gitignored, so your key never gets committed.

# Master switch for the agent pipeline.
#   true  → agents run; each case is processed one by one after ingest.
#   false → simulate an LLM outage (no API token, Ollama down): cases are still
#           accepted and stored, but they stay at status 'received'. No API key
#           is needed in this mode. Flip back to true and restart the backend —
#           the parked cases are then replayed automatically on startup.
# Requires a backend restart to take effect.
LLM_AVAILABLE=true

# Which LLM backend the agents use. See backend/src/carebridge/llm/.
#   local | ollama     → Ollama, on your machine (no key, no egress)
#   anthropic | claude → Claude API      (needs ANTHROPIC_API_KEY)
#   gemini | google    → Gemini API      (needs GEMINI_API_KEY + `pip install google-genai`)
LLM_PROVIDER=local

# --- local (Ollama) settings ------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# --- anthropic (Claude API) settings ----------------------------------------
# Get a key at https://platform.claude.com/ — required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- gemini (Google AI Studio) settings -------------------------------------
# Get a key at https://aistudio.google.com/apikey — required when LLM_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- logging ------------------------------------------------------------------
# LOG_LEVEL=INFO            # DEBUG shows one line per LLM round-trip
# LIBRARY_LOG_LEVEL=WARNING # floor for httpx / vendor SDKs / sqlalchemy
# UVICORN_ACCESS_LOG=0      # 1 re-enables uvicorn's own (duplicate) access log

# --- database -----------------------------------------------------------------
# Default (unset) matches the docker-compose Postgres:
#   postgresql+psycopg2://carebridge:carebridge@localhost:5432/carebridge
# For a locally installed Postgres, point at your own user/db instead, e.g.:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/careai
