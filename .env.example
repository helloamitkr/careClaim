# CareBridge AI — LLM configuration.
# Copy this file to `.env` (repo root or backend/) and fill in your values.
# `.env` is gitignored, so your key never gets committed.

# Which LLM backend the agents use: "local" (Ollama) or "anthropic" (Claude API).
LLM_PROVIDER=local

# --- local (Ollama) settings ------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# --- anthropic (Claude API) settings ----------------------------------------
# Get a key at https://platform.claude.com/ — required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- database (optional override) --------------------------------------------
# DATABASE_URL=postgresql+psycopg2://carebridge:carebridge@localhost:5432/carebridge
